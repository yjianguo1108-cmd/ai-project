<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.grain.system.module.warehouse.mapper.InventoryCheckDetailMapper">

    <resultMap id="CheckDetailMap" type="com.grain.system.module.warehouse.entity.InventoryCheckDetail">
        <id column="id" property="id"/>
        <result column="check_id" property="checkId"/>
        <result column="inventory_id" property="inventoryId"/>
        <result column="grain_id" property="grainId"/>
        <result column="grain_type" property="grainType"/>
        <result column="grain_grade" property="grainGrade"/>
        <result column="position_id" property="positionId"/>
        <result column="position_name" property="positionName"/>
        <result column="book_qty" property="bookQty"/>
        <result column="actual_qty" property="actualQty"/>
        <result column="diff_qty" property="diffQty"/>
        <result column="diff_rate" property="diffRate"/>
        <result column="is_over_threshold" property="isOverThreshold"/>
        <result column="photo_urls" property="photoUrls"/>
        <result column="handle_type" property="handleType"/>
        <result column="handle_reason" property="handleReason"/>
        <result column="handle_user_id" property="handleUserId"/>
        <result column="handle_time" property="handleTime"/>
        <result column="operator_id" property="operatorId"/>
        <result column="check_time" property="checkTime"/>
    </resultMap>

    <select id="selectDetailList" resultMap="CheckDetailMap">
        SELECT d.id, d.check_id, d.inventory_id, d.grain_id, d.position_id,
               d.book_qty, d.actual_qty, d.diff_qty, d.diff_rate,
               d.is_over_threshold, d.photo_urls, d.handle_type, d.handle_reason,
               d.handle_user_id, d.handle_time, d.operator_id, d.check_time,
               g.grain_type,
               g.grain_grade,
               s.position_name
        FROM t_inventory_check_detail d
        LEFT JOIN t_grain g ON d.grain_id = g.id
        LEFT JOIN t_storage_position s ON d.position_id = s.id
        WHERE d.check_id = #{checkId}
        ORDER BY d.id
    </select>

</mapper>