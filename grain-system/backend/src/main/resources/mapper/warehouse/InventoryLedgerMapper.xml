<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.grain.system.module.warehouse.mapper.InventoryLedgerMapper">

    <resultMap id="InventoryLedgerVOMap" type="com.grain.system.module.warehouse.vo.InventoryLedgerVO">
        <id column="id" property="id"/>
        <result column="grain_id" property="grainId"/>
        <result column="grain_type" property="grainType"/>
        <result column="grain_grade" property="grainGrade"/>
        <result column="position_id" property="storagePositionId"/>
        <result column="position_name" property="storagePositionName"/>
        <result column="current_stock" property="currentWeight"/>
        <result column="ref_price" property="refPrice"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectLedgerPage" resultMap="InventoryLedgerVOMap">
        SELECT i.id, i.grain_id, i.position_id,
               i.current_stock,
               g.grain_type, g.grain_grade,
               g.ref_purchase_price AS ref_price,
               i.current_stock * g.ref_purchase_price AS total_amount,
               s.position_name,
               i.create_time, i.update_time
        FROM t_inventory i
        INNER JOIN t_grain g ON i.grain_id = g.id
        INNER JOIN t_storage_position s ON i.position_id = s.id
        WHERE i.status = 1
        <if test="grainId != null">
            AND i.grain_id = #{grainId}
        </if>
        <if test="storagePositionId != null">
            AND i.position_id = #{storagePositionId}
        </if>
        ORDER BY i.update_time DESC
    </select>

</mapper>