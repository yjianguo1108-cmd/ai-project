<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.grain.system.module.purchase.mapper.WeighingRecordMapper">

    <resultMap id="WeighingRecordVOMap" type="com.grain.system.module.purchase.vo.WeighingRecordVO">
        <id column="id" property="id"/>
        <result column="weigh_no" property="weighNo"/>
        <result column="reserve_id" property="reserveId"/>
        <result column="reserve_no" property="reserveNo"/>
        <result column="weighbridge_id" property="weighbridgeId"/>
        <result column="weighbridge_name" property="weighbridgeName"/>
        <result column="gross_weight" property="grossWeight"/>
        <result column="tare_weight" property="tareWeight"/>
        <result column="net_weight" property="netWeight"/>
        <result column="weigh_time" property="weighTime"/>
        <result column="data_source" property="dataSource"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="audit_user_id" property="auditUserId"/>
        <result column="audit_user_name" property="auditUserName"/>
        <result column="audit_time" property="auditTime"/>
        <result column="create_user_id" property="createUserId"/>
        <result column="create_user_name" property="createUserName"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectWeighingPage" resultMap="WeighingRecordVOMap">
        SELECT w.id, w.weigh_no, w.reserve_id, w.weighbridge_id, w.gross_weight,
               w.tare_weight, w.net_weight, w.weigh_time, w.data_source, w.status, w.remark,
               w.audit_user_id, w.audit_time, w.create_user_id, w.create_time,
               r.reserve_no,
               d.device_name AS weighbridge_name,
               au.real_name AS audit_user_name,
               cu.real_name AS create_user_name
        FROM t_weighing_record w
        LEFT JOIN t_purchase_reserve r ON w.reserve_id = r.id
        LEFT JOIN t_device_base d ON w.weighbridge_id = d.id
        LEFT JOIN t_user au ON w.audit_user_id = au.id
        LEFT JOIN t_user cu ON w.create_user_id = cu.id
        WHERE 1=1
        <if test="keyword != null and keyword != ''">
            AND (w.weigh_no LIKE CONCAT('%', #{keyword}, '%')
                 OR r.reserve_no LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="status != null">
            AND w.status = #{status}
        </if>
        <if test="reserveId != null">
            AND w.reserve_id = #{reserveId}
        </if>
        ORDER BY w.create_time DESC
    </select>

</mapper>